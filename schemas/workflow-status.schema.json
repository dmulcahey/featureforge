{
  "$defs": {
    "ContractDiagnostic": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "type": "object"
    },
    "PlanFidelityGateReport": {
      "properties": {
        "diagnostics": {
          "items": {
            "$ref": "#/$defs/ContractDiagnostic"
          },
          "type": "array"
        },
        "provenance_source": {
          "type": "string"
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "receipt_path": {
          "type": "string"
        },
        "reviewer_stage": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "verified_execution_topology": {
          "type": "boolean"
        },
        "verified_requirement_index": {
          "type": "boolean"
        },
        "verified_spec_reference_fidelity": {
          "type": "boolean"
        },
        "verified_task_contract": {
          "type": "boolean"
        },
        "verified_task_determinism": {
          "type": "boolean"
        }
      },
      "required": [
        "state",
        "receipt_path",
        "reviewer_stage",
        "provenance_source",
        "verified_requirement_index",
        "verified_execution_topology",
        "verified_task_contract",
        "verified_task_determinism",
        "verified_spec_reference_fidelity",
        "reason_codes",
        "diagnostics"
      ],
      "type": "object"
    },
    "WorkflowDiagnostic": {
      "properties": {
        "artifact": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "remediation": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "artifact",
        "message",
        "remediation"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "contract_state": {
      "type": "string"
    },
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/WorkflowDiagnostic"
      },
      "type": "array"
    },
    "manifest_path": {
      "type": "string"
    },
    "next_skill": {
      "type": "string"
    },
    "note": {
      "type": "string"
    },
    "plan_candidate_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "plan_fidelity_receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlanFidelityGateReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "plan_path": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "root": {
      "type": "string"
    },
    "scan_truncated": {
      "type": "boolean"
    },
    "schema_version": {
      "const": 3,
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "spec_candidate_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "spec_path": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "status",
    "next_skill",
    "spec_path",
    "plan_path",
    "contract_state",
    "reason_codes",
    "diagnostics",
    "scan_truncated",
    "spec_candidate_count",
    "plan_candidate_count",
    "manifest_path",
    "root",
    "reason",
    "note"
  ],
  "title": "WorkflowRoute",
  "type": "object"
}