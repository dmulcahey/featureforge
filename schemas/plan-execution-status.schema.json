{
  "$defs": {
    "AggregateEvaluationState": {
      "enum": [
        "pass",
        "pending",
        "fail",
        "blocked"
      ],
      "type": "string"
    },
    "Blocker": {
      "properties": {
        "category": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "next_public_action": {
          "type": [
            "string",
            "null"
          ]
        },
        "record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope_key": {
          "type": "string"
        },
        "scope_type": {
          "type": "string"
        }
      },
      "required": [
        "category",
        "scope_type",
        "scope_key",
        "details"
      ],
      "type": "object"
    },
    "ChunkId": {
      "type": "string"
    },
    "ChunkingStrategy": {
      "enum": [
        "task",
        "task-group",
        "whole-run"
      ],
      "type": "string"
    },
    "DownstreamFreshnessState": {
      "enum": [
        "not_required",
        "missing",
        "fresh",
        "stale"
      ],
      "type": "string"
    },
    "EvaluationVerdict": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ],
      "type": "string"
    },
    "EvaluatorKind": {
      "enum": [
        "spec_compliance",
        "code_quality"
      ],
      "type": "string"
    },
    "EvaluatorPolicyName": {
      "type": "string"
    },
    "ExecutionCommandKindSchema": {
      "enum": [
        "begin",
        "complete",
        "reopen"
      ],
      "type": "string"
    },
    "ExecutionRunId": {
      "type": "string"
    },
    "HarnessPhase": {
      "enum": [
        "implementation_handoff",
        "execution_preflight",
        "contract_drafting",
        "contract_pending_approval",
        "contract_approved",
        "executing",
        "evaluating",
        "repairing",
        "pivot_required",
        "handoff_required",
        "final_review_pending",
        "qa_pending",
        "document_release_pending",
        "ready_for_branch_completion"
      ],
      "type": "string"
    },
    "NextActionSchema": {
      "enum": [
        "advance late stage",
        "finish branch",
        "close current task",
        "continue execution",
        "request task review",
        "request final review",
        "execution reentry required",
        "hand off",
        "pivot / return to planning",
        "refresh test plan",
        "repair review state / reenter execution",
        "resolve release blocker",
        "run QA",
        "wait for external review result",
        "run verification"
      ],
      "type": "string"
    },
    "NextPublicAction": {
      "properties": {
        "args_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": "string"
        }
      },
      "required": [
        "command"
      ],
      "type": "object"
    },
    "PhaseDetailSchema": {
      "enum": [
        "blocked_runtime_bug",
        "branch_closure_recording_required_for_release_readiness",
        "execution_in_progress",
        "execution_reentry_required",
        "final_review_dispatch_required",
        "final_review_outcome_pending",
        "final_review_recording_ready",
        "finish_completion_gate_ready",
        "finish_review_gate_ready",
        "handoff_recording_required",
        "planning_reentry_required",
        "qa_recording_required",
        "release_blocker_resolution_required",
        "release_readiness_recording_ready",
        "runtime_reconcile_required",
        "task_closure_recording_ready",
        "task_review_dispatch_required",
        "task_review_result_pending",
        "test_plan_refresh_required"
      ],
      "type": "string"
    },
    "PublicExecutionCommandContext": {
      "additionalProperties": false,
      "properties": {
        "command_kind": {
          "$ref": "#/$defs/ExecutionCommandKindSchema"
        },
        "step_id": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "command_kind",
        "task_number",
        "step_id"
      ],
      "type": "object"
    },
    "PublicRecordingContext": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "branch_closure_id"
          ]
        },
        {
          "required": [
            "task_number"
          ]
        }
      ],
      "minProperties": 1,
      "properties": {
        "branch_closure_id": {
          "type": "string"
        },
        "dispatch_id": {
          "type": "string"
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "PublicRepairTarget": {
      "properties": {
        "command_kind": {
          "$ref": "#/$defs/PublicRepairTargetCommandKindSchema"
        },
        "expires_when_fingerprint_changes": {
          "type": "boolean"
        },
        "reason_code": {
          "type": "string"
        },
        "source_record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "step": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "task": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "command_kind",
        "reason_code",
        "expires_when_fingerprint_changes"
      ],
      "type": "object"
    },
    "PublicRepairTargetCommandKindSchema": {
      "enum": [
        "begin",
        "complete",
        "reopen",
        "transfer",
        "close-current-task",
        "repair-review-state",
        "advance-late-stage"
      ],
      "type": "string"
    },
    "PublicReviewStateTaskClosure": {
      "properties": {
        "closure_record_id": {
          "type": "string"
        },
        "contract_identity": {
          "type": "string"
        },
        "effective_reviewed_surface_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "reviewed_state_id": {
          "type": "string"
        },
        "task": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "task",
        "closure_record_id",
        "reviewed_state_id",
        "contract_identity",
        "effective_reviewed_surface_paths"
      ],
      "type": "object"
    },
    "QaRequirementSchema": {
      "enum": [
        "required",
        "not-required"
      ],
      "type": "string"
    },
    "RequiredFollowUpSchema": {
      "enum": [
        "execution_reentry",
        "repair_review_state",
        "request_external_review",
        "run_verification",
        "advance_late_stage",
        "resolve_release_blocker",
        "record_handoff"
      ],
      "type": "string"
    },
    "ResetPolicy": {
      "enum": [
        "none",
        "chunk-boundary",
        "adaptive"
      ],
      "type": "string"
    },
    "ReviewStateStatusSchema": {
      "enum": [
        "clean",
        "stale_unreviewed",
        "missing_current_closure"
      ],
      "type": "string"
    },
    "StateKindSchema": {
      "enum": [
        "actionable_public_command",
        "waiting_external_input",
        "terminal",
        "blocked_runtime_bug"
      ],
      "type": "string"
    },
    "StatusBlockingRecord": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "record_type": {
          "type": "string"
        },
        "required_follow_up": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequiredFollowUpSchema"
            },
            {
              "type": "null"
            }
          ]
        },
        "review_state_status": {
          "type": "string"
        },
        "scope_key": {
          "type": "string"
        },
        "scope_type": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "scope_type",
        "scope_key",
        "record_type",
        "review_state_status",
        "message"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "task_closure_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "task_number"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "release_readiness_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "release_blocker_resolution_required"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "final_review_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "else": {
        "not": {
          "required": [
            "recording_context"
          ]
        }
      },
      "if": {
        "properties": {
          "phase_detail": {
            "enum": [
              "task_closure_recording_ready",
              "release_readiness_recording_ready",
              "release_blocker_resolution_required",
              "final_review_recording_ready"
            ]
          }
        }
      }
    },
    {
      "else": {
        "not": {
          "required": [
            "execution_command_context"
          ]
        }
      },
      "if": {
        "properties": {
          "harness_phase": {
            "const": "executing"
          }
        }
      }
    },
    {
      "else": {
        "required": [
          "recommended_command"
        ]
      },
      "if": {
        "properties": {
          "phase_detail": {
            "enum": [
              "task_review_dispatch_required",
              "task_review_result_pending",
              "finish_review_gate_ready",
              "finish_completion_gate_ready",
              "final_review_dispatch_required",
              "final_review_outcome_pending",
              "test_plan_refresh_required"
            ]
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "recommended_command"
          ]
        }
      }
    }
  ],
