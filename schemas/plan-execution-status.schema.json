{
  "$defs": {
    "AggregateEvaluationState": {
      "enum": [
        "pass",
        "pending",
        "fail",
        "blocked"
      ],
      "type": "string"
    },
    "ChunkId": {
      "type": "string"
    },
    "ChunkingStrategy": {
      "enum": [
        "task",
        "task-group",
        "whole-run"
      ],
      "type": "string"
    },
    "DownstreamFreshnessState": {
      "enum": [
        "not_required",
        "missing",
        "fresh",
        "stale"
      ],
      "type": "string"
    },
    "EvaluationVerdict": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ],
      "type": "string"
    },
    "EvaluatorKind": {
      "enum": [
        "spec_compliance",
        "code_quality"
      ],
      "type": "string"
    },
    "EvaluatorPolicyName": {
      "type": "string"
    },
    "ExecutionRunId": {
      "type": "string"
    },
    "FollowUpOverrideSchema": {
      "enum": [
        "none",
        "record_handoff",
        "record_pivot"
      ],
      "type": "string"
    },
    "HarnessPhase": {
      "enum": [
        "implementation_handoff",
        "execution_preflight",
        "contract_drafting",
        "contract_pending_approval",
        "contract_approved",
        "executing",
        "evaluating",
        "repairing",
        "pivot_required",
        "handoff_required",
        "final_review_pending",
        "qa_pending",
        "document_release_pending",
        "ready_for_branch_completion"
      ],
      "type": "string"
    },
    "NextActionSchema": {
      "enum": [
        "advance late stage",
        "close current task",
        "continue execution",
        "dispatch review",
        "execution reentry required",
        "hand off",
        "pivot / return to planning",
        "record branch closure",
        "refresh test plan",
        "repair review state / reenter execution",
        "resolve release blocker",
        "run QA",
        "run finish completion gate",
        "run finish review gate",
        "wait for external review result"
      ],
      "type": "string"
    },
    "PhaseDetailSchema": {
      "enum": [
        "branch_closure_recording_required_for_release_readiness",
        "execution_in_progress",
        "execution_reentry_required",
        "final_review_dispatch_required",
        "final_review_outcome_pending",
        "finish_completion_gate_ready",
        "finish_review_gate_ready",
        "handoff_recording_required",
        "planning_reentry_required",
        "qa_recording_required",
        "release_blocker_resolution_required",
        "release_readiness_recording_ready",
        "task_review_dispatch_required",
        "task_review_result_pending",
        "test_plan_refresh_required"
      ],
      "type": "string"
    },
    "PublicExecutionCommandContext": {
      "properties": {
        "command_kind": {
          "type": "string"
        },
        "step_id": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "command_kind"
      ],
      "type": "object"
    },
    "PublicRecordingContext": {
      "properties": {
        "branch_closure_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "dispatch_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PublicReviewStateTaskClosure": {
      "properties": {
        "closure_record_id": {
          "type": "string"
        },
        "contract_identity": {
          "type": "string"
        },
        "effective_reviewed_surface_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "reviewed_state_id": {
          "type": "string"
        },
        "task": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
