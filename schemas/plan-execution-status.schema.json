        },
        "record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "record_type": {
          "type": "string"
        },
        "required_follow_up": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_state_status": {
          "type": "string"
        },
