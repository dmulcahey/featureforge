{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPacket",
  "type": "object",
  "properties": {
    "constraint_obligations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PacketObligation"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "done_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "done_when_obligations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PacketObligation"
      }
    },
    "file_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TaskPacketFileEntry"
      }
    },
    "file_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "markdown": {
      "type": "string"
    },
    "packet_contract_version": {
      "type": "string"
    },
    "packet_fingerprint": {
      "type": "string"
    },
    "plan_fingerprint": {
      "type": "string"
    },
    "plan_path": {
      "type": "string"
    },
    "plan_revision": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_spec_fingerprint": {
      "type": "string"
    },
    "source_spec_path": {
      "type": "string"
    },
    "source_spec_revision": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "task_number": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "task_title": {
      "type": "string"
    }
  },
  "required": [
    "packet_contract_version",
    "plan_path",
    "plan_revision",
    "plan_fingerprint",
    "source_spec_path",
    "source_spec_revision",
    "source_spec_fingerprint",
    "task_number",
    "task_title",
    "goal",
    "context",
    "constraints",
    "constraint_obligations",
    "done_when",
    "done_when_obligations",
    "requirement_ids",
    "file_entries",
    "file_scope",
    "generated_at",
    "packet_fingerprint",
    "markdown"
  ],
  "$defs": {
    "PacketObligation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "index",
        "text"
      ]
    },
    "TaskPacketFileEntry": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "normalized_path": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "action",
        "path",
        "normalized_path"
      ]
    }
  }
}