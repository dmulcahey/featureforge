{
  "$defs": {
    "Blocker": {
      "properties": {
        "category": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "next_public_action": {
          "type": [
            "string",
            "null"
          ]
        },
        "record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope_key": {
          "type": "string"
        },
        "scope_type": {
          "type": "string"
        }
      },
      "required": [
        "category",
        "scope_type",
        "scope_key",
        "details"
      ],
      "type": "object"
    },
    "NextPublicAction": {
      "properties": {
        "args_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": "string"
        }
      },
      "required": [
        "command"
      ],
      "type": "object"
    },
    "PublicCommandInputKind": {
      "enum": [
        "text",
        "enum",
        "path"
      ],
      "type": "string"
    },
    "PublicCommandInputRequirement": {
      "properties": {
        "kind": {
          "$ref": "#/$defs/PublicCommandInputKind"
        },
        "must_exist": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "required_when": {
          "type": [
            "string",
            "null"
          ]
        },
        "values": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "name",
        "kind"
      ],
      "type": "object"
    },
    "WorkflowOperatorCommandKindSchema": {
      "enum": [
        "begin",
        "complete",
        "reopen"
      ],
      "type": "string"
    },
    "WorkflowOperatorExecutionCommandContext": {
      "additionalProperties": false,
      "properties": {
        "command_kind": {
          "$ref": "#/$defs/WorkflowOperatorCommandKindSchema"
        },
        "step_id": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "command_kind",
        "task_number",
        "step_id"
      ],
      "type": "object"
    },
    "WorkflowOperatorNextActionSchema": {
      "enum": [
        "advance late stage",
        "finish branch",
        "close current task",
        "continue execution",
        "request final review",
        "execution reentry required",
        "hand off",
        "pivot / return to planning",
        "refresh test plan",
        "repair review state / reenter execution",
        "resolve release blocker",
        "run QA",
        "run verification",
        "wait for external review result"
      ],
      "type": "string"
    },
    "WorkflowOperatorPhaseDetailSchema": {
      "enum": [
        "blocked_runtime_bug",
        "execution_in_progress",
        "execution_preflight_required",
        "execution_reentry_required",
        "task_review_result_pending",
        "task_closure_recording_ready",
        "branch_closure_recording_required_for_release_readiness",
        "release_readiness_recording_ready",
        "release_blocker_resolution_required",
        "final_review_dispatch_required",
        "final_review_outcome_pending",
        "final_review_recording_ready",
        "qa_recording_required",
        "runtime_reconcile_required",
        "test_plan_refresh_required",
        "finish_review_gate_ready",
        "finish_completion_gate_ready",
        "handoff_recording_required",
        "planning_reentry_required"
      ],
      "type": "string"
    },
    "WorkflowOperatorPhaseSchema": {
      "enum": [
        "blocked",
        "executing",
        "execution_preflight",
        "task_closure_pending",
        "document_release_pending",
        "final_review_pending",
        "qa_pending",
        "ready_for_branch_completion",
        "handoff_required",
        "pivot_required"
      ],
      "type": "string"
    },
    "WorkflowOperatorQaRequirementSchema": {
      "enum": [
        "required",
        "not-required"
      ],
      "type": "string"
    },
    "WorkflowOperatorRecordingContext": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "branch_closure_id"
          ]
        },
        {
          "required": [
            "task_number"
          ]
        }
      ],
      "minProperties": 1,
      "properties": {
        "branch_closure_id": {
          "type": "string"
        },
        "dispatch_id": {
          "type": "string"
        },
        "task_number": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "WorkflowOperatorReviewStateStatusSchema": {
      "enum": [
        "clean",
        "stale_unreviewed",
        "missing_current_closure"
      ],
      "type": "string"
    },
    "WorkflowOperatorStateKindSchema": {
      "enum": [
        "actionable_public_command",
        "waiting_external_input",
        "terminal",
        "blocked_runtime_bug"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "task_closure_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "task_number"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "release_readiness_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "release_blocker_resolution_required"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase_detail": {
            "const": "final_review_recording_ready"
          }
        }
      },
      "then": {
        "properties": {
          "recording_context": {
            "required": [
              "branch_closure_id"
            ]
          }
        },
        "required": [
          "recording_context"
        ]
      }
    },
    {
      "else": {
        "not": {
          "required": [
            "recording_context"
          ]
        }
      },
      "if": {
        "properties": {
          "phase_detail": {
            "enum": [
              "task_closure_recording_ready",
              "release_readiness_recording_ready",
              "release_blocker_resolution_required",
              "final_review_recording_ready"
            ]
          }
        }
      }
    },
    {
      "else": {
        "not": {
          "required": [
            "execution_command_context"
          ]
        }
      },
      "if": {
        "properties": {
          "phase": {
            "const": "executing"
          }
        }
      }
    },
    {
      "else": {
        "required": [
          "recommended_command"
        ]
      },
      "if": {
        "properties": {
          "phase_detail": {
            "enum": [
              "task_review_result_pending",
              "execution_in_progress",
              "runtime_reconcile_required",
              "finish_review_gate_ready",
              "finish_completion_gate_ready",
              "final_review_dispatch_required",
              "final_review_outcome_pending",
              "test_plan_refresh_required"
            ]
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "recommended_command"
          ]
        }
      }
    }
  ],
  "properties": {
    "base_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "blockers": {
      "items": {
        "$ref": "#/$defs/Blocker"
      },
      "type": "array"
    },
    "blocking_reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "blocking_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocking_task": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "execution_command_context": {
      "$ref": "#/$defs/WorkflowOperatorExecutionCommandContext"
    },
    "external_wait_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "finish_review_gate_pass_branch_closure_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_action": {
      "$ref": "#/$defs/WorkflowOperatorNextActionSchema"
    },
    "next_public_action": {
      "anyOf": [
        {
          "$ref": "#/$defs/NextPublicAction"
        },
        {
          "type": "null"
        }
      ]
    },
    "phase": {
      "$ref": "#/$defs/WorkflowOperatorPhaseSchema"
    },
    "phase_detail": {
      "$ref": "#/$defs/WorkflowOperatorPhaseDetailSchema"
    },
    "plan_path": {
      "type": "string"
    },
    "projection_mode": {
      "type": "string"
    },
    "qa_requirement": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkflowOperatorQaRequirementSchema"
        },
        {
          "type": "null"
        }
      ]
    },
    "raw_workspace_tree_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "recommended_command": {
      "type": "string"
    },
    "recommended_public_command_argv": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "recording_context": {
      "$ref": "#/$defs/WorkflowOperatorRecordingContext"
    },
    "required_inputs": {
      "items": {
        "$ref": "#/$defs/PublicCommandInputRequirement"
      },
      "type": "array"
    },
    "review_state_status": {
      "$ref": "#/$defs/WorkflowOperatorReviewStateStatusSchema"
    },
    "schema_version": {
      "const": 3,
      "format": "uint32",
      "maximum": 3,
      "minimum": 3,
      "type": "integer"
    },
    "semantic_workspace_tree_id": {
      "type": "string"
    },
    "spec_path": {
      "type": "string"
    },
    "state_dir_projection_paths": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "state_kind": {
      "$ref": "#/$defs/WorkflowOperatorStateKindSchema"
    },
    "tracked_projection_paths": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tracked_projections_current": {
      "type": "boolean"
    }
  },
  "required": [
    "schema_version",
    "phase",
    "phase_detail",
    "review_state_status",
    "next_action",
    "blocking_reason_codes",
    "state_kind",
    "semantic_workspace_tree_id",
    "spec_path",
    "plan_path",
    "projection_mode",
    "state_dir_projection_paths",
    "tracked_projection_paths",
    "tracked_projections_current"
  ],
  "title": "WorkflowOperator",
  "type": "object"
}