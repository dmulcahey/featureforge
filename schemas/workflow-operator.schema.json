{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowOperator",
  "type": "object",
  "properties": {
    "execution_command_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkflowOperatorExecutionCommandContext"
        },
        {
          "type": "null"
        }
      ]
    },
    "finish_review_gate_pass_branch_closure_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "follow_up_override": {
      "$ref": "#/$defs/WorkflowOperatorFollowUpOverrideSchema"
    },
    "next_action": {
      "$ref": "#/$defs/WorkflowOperatorNextActionSchema"
    },
    "phase": {
      "$ref": "#/$defs/WorkflowOperatorPhaseSchema"
    },
    "phase_detail": {
      "$ref": "#/$defs/WorkflowOperatorPhaseDetailSchema"
    },
    "plan_path": {
      "type": "string"
    },
    "qa_requirement": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkflowOperatorQaRequirementSchema"
        },
        {
          "type": "null"
        }
      ]
    },
    "recommended_command": {
      "type": [
        "string",
        "null"
      ]
    },
    "recording_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkflowOperatorRecordingContext"
        },
        {
          "type": "null"
        }
      ]
    },
    "review_state_status": {
      "$ref": "#/$defs/WorkflowOperatorReviewStateStatusSchema"
    },
    "schema_version": {
      "const": 1,
      "type": "integer",
      "format": "uint32",
      "minimum": 1,
      "maximum": 1
    },
    "spec_path": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "phase",
    "phase_detail",
    "review_state_status",
    "follow_up_override",
    "next_action",
    "spec_path",
    "plan_path"
  ],
  "$defs": {
    "WorkflowOperatorCommandKindSchema": {
      "type": "string",
      "enum": [
        "begin",
        "complete",
        "reopen"
      ]
    },
    "WorkflowOperatorExecutionCommandContext": {
      "type": "object",
      "properties": {
        "command_kind": {
          "$ref": "#/$defs/WorkflowOperatorCommandKindSchema"
        },
        "step_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "task_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "command_kind"
      ]
    },
    "WorkflowOperatorFollowUpOverrideSchema": {
      "type": "string",
      "enum": [
        "none",
        "record_handoff",
        "record_pivot"
      ]
    },
    "WorkflowOperatorNextActionSchema": {
      "type": "string",
      "enum": [
        "advance late stage",
        "close current task",
        "continue execution",
        "dispatch review",
        "dispatch final review",
        "execution reentry required",
        "hand off",
        "pivot / return to planning",
        "record branch closure",
        "refresh test plan",
        "repair review state / reenter execution",
        "resolve release blocker",
        "run QA",
        "run finish completion gate",
        "run finish review gate",
        "wait for external review result"
      ]
    },
    "WorkflowOperatorPhaseDetailSchema": {
      "type": "string",
      "enum": [
        "execution_in_progress",
        "execution_reentry_required",
        "task_review_dispatch_required",
        "task_review_result_pending",
        "task_closure_recording_ready",
        "branch_closure_recording_required_for_release_readiness",
        "release_readiness_recording_ready",
        "release_blocker_resolution_required",
        "final_review_dispatch_required",
        "final_review_outcome_pending",
        "final_review_recording_ready",
        "qa_recording_required",
        "test_plan_refresh_required",
        "finish_review_gate_ready",
        "finish_completion_gate_ready",
        "handoff_recording_required",
        "planning_reentry_required"
      ]
    },
    "WorkflowOperatorPhaseSchema": {
      "type": "string",
      "enum": [
        "executing",
        "task_closure_pending",
        "document_release_pending",
        "final_review_pending",
        "qa_pending",
        "ready_for_branch_completion",
        "handoff_required",
        "pivot_required"
      ]
    },
    "WorkflowOperatorQaRequirementSchema": {
      "type": "string",
      "enum": [
        "required",
        "not-required"
      ]
    },
    "WorkflowOperatorRecordingContext": {
      "type": "object",
      "properties": {
        "branch_closure_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "dispatch_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      }
    },
    "WorkflowOperatorReviewStateStatusSchema": {
      "type": "string",
      "enum": [
        "clean",
        "stale_unreviewed",
        "missing_current_closure"
      ]
    }
  }
}
